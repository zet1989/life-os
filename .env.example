# Секреты и конфигурация (НЕ КОММИТИТЬ В GIT)
# Скопируй этот файл: cp .env.example .env
# Заполни значения

# === Telegram Bot Tokens ===
BOT_TOKEN_HEALTH=
BOT_TOKEN_ASSETS=
BOT_TOKEN_BUSINESS=
BOT_TOKEN_PARTNER=
BOT_TOKEN_MENTOR=
BOT_TOKEN_FAMILY=
BOT_TOKEN_PSYCHOLOGY=
BOT_TOKEN_MASTER=

# === Supabase ===
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...

# === AI APIs ===
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Настройки ===
LOG_LEVEL=INFO
ADMIN_USER_ID=123456789

# === Webhook (продакшен, опционально) ===
USE_WEBHOOK=false
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PORT=8443
WEBHOOK_SECRET=your-random-secret-here

# === Budget limiter ===
API_DAILY_LIMIT_USD=2.0
API_MONTHLY_LIMIT_USD=20.0
