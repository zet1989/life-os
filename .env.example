# Секреты и конфигурация (НЕ КОММИТИТЬ В GIT)
# Скопируй этот файл: cp .env.example .env
# Заполни значения

# === Telegram Bot Tokens ===
BOT_TOKEN_HEALTH=1234567890:AAExampleHealthTokenXXXXXXXXXXXXXXX
BOT_TOKEN_ASSETS=1234567890:AAExampleAssetsTokenXXXXXXXXXXXXXXX
BOT_TOKEN_BUSINESS=1234567890:AAExampleBusinessTokenXXXXXXXXXXXXX
BOT_TOKEN_PARTNER=1234567890:AAExamplePartnerTokenXXXXXXXXXXXXXX
BOT_TOKEN_MENTOR=1234567890:AAExampleMentorTokenXXXXXXXXXXXXXXX
BOT_TOKEN_FAMILY=1234567890:AAExampleFamilyTokenXXXXXXXXXXXXXXX
BOT_TOKEN_PSYCHOLOGY=1234567890:AAExamplePsychologyTokenXXXXXXXXXX
BOT_TOKEN_MASTER=1234567890:AAExampleMasterTokenXXXXXXXXXXXXXXX

# === PostgreSQL ===
DATABASE_URL=postgresql://lifeos:lifeos@postgres:5432/lifeos

# === AI APIs ===
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Настройки ===
LOG_LEVEL=INFO
ADMIN_USER_ID=123456789

# === Webhook (продакшен, опционально) ===
USE_WEBHOOK=false
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PORT=8443
WEBHOOK_SECRET=your-random-secret-here

# === Budget limiter ===
API_DAILY_LIMIT_USD=2.0
API_MONTHLY_LIMIT_USD=20.0

# === Todoist ===
TODOIST_API_TOKEN=your-todoist-api-token
